# MedFlow Pro - Plantilla de Variables de Entorno
# ⚠️ COPIAR ESTE ARCHIVO A .env Y COMPLETAR CON VALORES REALES
# ⚠️ NUNCA SUBIR .env A GITHUB

# ==================== MONGODB ====================
# Conexión a MongoDB (local o Atlas)
MONGO_USER=admin
MONGO_PASS=TU_CONTRASEÑA_AQUÍ
MONGO_URI=mongodb://admin:TU_CONTRASEÑA_AQUÍ@mongodb:27017/medflow

# ==================== JWT SECURITY ====================
# Clave secreta - GENERAR CON: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TU_CLAVE_SECRETA_AQUÍ_MINIMO_32_CARACTERES

# Algoritmo de encriptación
ALGORITHM=HS256

# Expiración de tokens
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS ====================
# Orígenes permitidos (separados por coma, sin espacios)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== ENTORNO ====================
ENV=development